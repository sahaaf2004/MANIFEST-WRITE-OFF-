
# Nuget packages
*.nupkg

# The packages folder can be ignored because of Package Restore
**/packages/*

# Výstupní složky sestavení
[Bb]in/
[Oo]bj/

# Soubory generované nástrojem ResGen
*.resources
*.resw

# Soubory generované za běhu
*generated.cs

# User-specific files
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Aa]rm/
[Aa]rm64/
[Ll]ogs/
[Ss]rc/**/bin
[Ss]rc/**/obj

# Visual Studio 2017 cache/options directory
.vs/

# Editor-based settings
*.suo
*.sln.opts

# Dotnet local user secrets
secrets.env

# Folders and files generated by Rider
.idea
*.sln.iml
