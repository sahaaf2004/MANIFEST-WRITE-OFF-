## 6. Database Schema

### Tables

```sql
-- Applications (main record)
applications (
  id                UUID PRIMARY KEY,
  r_number          TEXT NOT NULL,
  port              TEXT NOT NULL,
  year              INT NOT NULL,
  bl_number         TEXT,
  ff_account_code   TEXT,
  consignee_code    TEXT,
  status            TEXT,  -- 'validated' | 'written_off' | 'amendment_pending' | 'finalized'
  write_off_ref     TEXT,
  created_at        TIMESTAMPTZ,
  updated_at        TIMESTAMPTZ,
  created_by        UUID REFERENCES auth.users
)

-- Validation results
validation_results (
  id                UUID PRIMARY KEY,
  application_id    UUID REFERENCES applications,
  field_name        TEXT,
  manifest_value    TEXT,
  evaluator_value   TEXT,
  match             BOOLEAN,
  fine_tier         INT,
  created_at        TIMESTAMPTZ
)

-- Amendment applications
amendments (
  id                UUID PRIMARY KEY,
  amendment_ref     TEXT UNIQUE,
  application_id    UUID REFERENCES applications,
  service_types     TEXT[],
  amendment_types   TEXT[],
  content_before    TEXT,
  content_after     TEXT,
  reason            TEXT,
  fine_amount       DECIMAL,
  status            TEXT,  -- 'pending_review' | 'approved' | 'rejected'
  reviewed_by       TEXT,
  reviewed_at       TIMESTAMPTZ,
  rejection_reason  TEXT,
  submitted_at      TIMESTAMPTZ,
  created_by        UUID REFERENCES auth.users
)

-- Document uploads
documents (
  id                UUID PRIMARY KEY,
  amendment_id      UUID REFERENCES amendments,
  document_type     TEXT,  -- 'amended_manifest' | 'bl_copy' | 'noc_exporter' | 'noc_shipper' | 'bl_cancel_letter' | 'bl_document'
  file_url          TEXT,
  file_name         TEXT,
  file_size         INT,
  uploaded_at       TIMESTAMPTZ
)

-- Payments
payments (
  id                UUID PRIMARY KEY,
  payment_ref       TEXT UNIQUE,
  amendment_id      UUID REFERENCES amendments,
  ff_account_code   TEXT,
  amount            DECIMAL,
  method            TEXT,
  status            TEXT,  -- 'initiated' | 'confirmed' | 'failed'
  transaction_ref   TEXT,
  initiated_at      TIMESTAMPTZ,
  confirmed_at      TIMESTAMPTZ
)

-- Audit log
audit_log (
  id                UUID PRIMARY KEY,
  application_id    UUID REFERENCES applications,
  event             TEXT,
  from_state        TEXT,
  to_state          TEXT,
  user_id           UUID,
  ip_address        TEXT,
  metadata          JSONB,
  created_at        TIMESTAMPTZ
)
```

