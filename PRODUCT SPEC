        "name": "ASYCUDA World",
        "base_url": os.getenv("ASYCUDA_BASE_URL"),
        "api_key": os.getenv("ASYCUDA_API_KEY"),
        "timeout": 10,
        "retries": 2,
        "headers": {"X-API-Key": "{api_key}", "Content-Type": "application/json"}
